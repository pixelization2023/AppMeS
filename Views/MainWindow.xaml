                       VerticalAlignment="Center"
                       FontSize="11"
                       Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                    <Border
                       Width="1"
                       Margin="12,2"
                       Background="{DynamicResource MaterialDesignDivider}" />
                    <materialDesign:PackIcon
                       Width="14"
                       Height="14"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       Kind="Database" />
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="11"
                       Text="数据库: 在线" />
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>
    </Grid>

</Window>
