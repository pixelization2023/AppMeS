<Window
    x:Class="AppMeS.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AppMeS.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="MainWindow"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Width="1600"
    Height="900"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d"
    WindowStartupLocation="CenterScreen">
    <!--  引入 MaterialDesign 默认样式与色彩  -->
    <Window.Resources>
        <Style BasedOn="{StaticResource MaterialDesignGroupBox}" TargetType="GroupBox" />
        <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="TextBox" />
        <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button" />
        <Style BasedOn="{StaticResource MaterialDesignDataGrid}" TargetType="DataGrid" />
        <!--  设计时示例数据  -->
        <x:Array x:Key="DesignOrders" Type="{x:Type sys:String}">
            <sys:String>WO2024001</sys:String>
            <sys:String>WO2024002</sys:String>
        </x:Array>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!--  第一行：标题栏（美化）  -->
        <materialDesign:ColorZone
           Grid.Row="0"
           Padding="12,0"
           Mode="PrimaryDark">
            <DockPanel>
                <!--  左侧 Logo 与标题  -->
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon
                       Width="24"
                       Height="24"
                       Margin="0,0,8,0"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Kind="CameraIris" />
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="CCD 视觉检测系统" />
                    <Border
                       Width="1"
                       Margin="16,4"
                       Background="{DynamicResource MaterialDesignDivider}" />
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Text="v2.1.0.0" />
                </StackPanel>

                <!--  右侧状态（模拟）  -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <materialDesign:PackIcon
                       Width="16"
                       Height="16"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       Foreground="LimeGreen"
                       Kind="Circle" />
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="12"
                       Text="系统在线" />
                    <Border
                       Width="1"
                       Margin="16,4"
                       Background="{DynamicResource MaterialDesignDivider}" />
                    <materialDesign:PackIcon
                       Width="16"
                       Height="16"
                       Margin="0,0,4,0"
                       VerticalAlignment="Center"
                       Kind="Account" />
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="12"
                       Text="Operator" />
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!--  第二行：主内容区域  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!--  ========== 第一列：侧边栏信息 / 快捷操作 ==========  -->
            <Border
               Margin="8,8,4,8"
               Background="{DynamicResource MaterialDesignCardBackground}"
               BorderBrush="{DynamicResource MaterialDesignDivider}"
               BorderThickness="1"
               CornerRadius="6">
                <StackPanel>
                    <!--  用户卡片  -->
                    <Border
                       Padding="16,16,16,8"
                       BorderBrush="{DynamicResource MaterialDesignDivider}"
                       BorderThickness="0,0,0,1">
                        <StackPanel>
                            <materialDesign:PackIcon
                               Width="40"
                               Height="40"
                               HorizontalAlignment="Center"
                               Kind="AccountCircleOutline" />
                            <TextBlock
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="当前操作员" />
                            <TextBlock
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="Admin" />
                        </StackPanel>
                    </Border>

                    <!--  设备状态摘要  -->
                    <StackPanel Margin="16,12">
                        <TextBlock
                           Margin="0,0,0,12"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="设备状态" />

                        <!--  状态项  -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!--<materialDesign:PackIcon
                               Grid.Column="0"
                               Width="16"
                               Height="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Kind="Camera" />-->
                            <!--<TextBlock
                               Grid.Column="1"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="相机连接" />
                           <TextBlock
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="LimeGreen"
                               Text="已连接" />-->
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!--<materialDesign:PackIcon
                               Grid.Column="0"
                               Width="16"
                               Height="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Kind="Lightbulb" />-->
                            <!--<TextBlock
                               Grid.Column="1"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="光源控制器" />
                           <TextBlock
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="LimeGreen"
                               Text="在线" />-->
                        </Grid>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon
                               Grid.Column="0"
                               Width="16"
                               Height="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Kind="Server" />
                            <TextBlock
                               Grid.Column="1"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Text="MES 连接" />
                            <TextBlock
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="Medium"
                               Foreground="Red"
                               Text="未连接" />
                        </Grid>
                    </StackPanel>

                    <Separator Margin="16,0" Style="{StaticResource MaterialDesignLightSeparator}" />

                    <!--  快捷操作按钮  -->
                    <StackPanel Margin="16,12">
                        <Button
                           Margin="0,4"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           ToolTip="开始自动检测"
                            Command="{Binding LoadOrdersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Margin="0,0,8,0" Kind="Play" />
                                <TextBlock Text="开始检测" />
                            </StackPanel>
                        </Button>
                        <Button
                           Margin="0,4"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           ToolTip="停止当前流程">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Margin="0,0,8,0" Kind="Stop" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>
                        <!--<Button
                           Margin="0,4"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           ToolTip="手动触发一次拍照">
                           <StackPanel Orientation="Horizontal">
                               <materialDesign:PackIcon Margin="0,0,8,0" Kind="Camera" />
                               <TextBlock Text="单次采集" />
                           </StackPanel>
                       </Button>-->
                    </StackPanel>

                    <Separator Margin="16,0" Style="{StaticResource MaterialDesignLightSeparator}" />

                    <!--  今日统计  -->
                    <StackPanel Margin="16,12">
                        <TextBlock
                           Margin="0,0,0,8"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Text="今日统计" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock
                                   FontSize="11"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="总检测数" />
                                <TextBlock
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="1,284" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock
                                   FontSize="11"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Text="良品率" />
                                <TextBlock
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="LimeGreen"
                                   Text="98.6%" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ========== 第二列：主显示区 & 设置 ==========  -->
            <TabControl
               Grid.Column="1"
               Margin="4,8"
               Style="{StaticResource MaterialDesignTabControl}">
                <!--  显示界面 Tab  -->
                <!--<TabItem Header="显示界面">
                   <Border
                       Margin="0"
                       Background="Black"
                       BorderBrush="{DynamicResource MaterialDesignDivider}"
                       BorderThickness="1"
                       CornerRadius="6">
                       <Grid>
                           -->
                <!--  图像显示区域（占位）  -->
                <!--
                           <Viewbox Margin="20" Stretch="Uniform">
                               <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                   <materialDesign:PackIcon
                                       Width="64"
                                       Height="64"
                                       HorizontalAlignment="Center"
                                       Foreground="#44FFFFFF"
                                       Kind="CameraOff" />
                                   <TextBlock
                                       Margin="0,12,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="14"
                                       Foreground="#88FFFFFF"
                                       Text="等待相机触发..." />
                                   <TextBlock
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="#55FFFFFF"
                                       Text="实时画面区域" />
                               </StackPanel>
                           </Viewbox>
                           -->
                <!--  十字准星装饰  -->
                <!--
                           <Line
                               Stretch="Uniform"
                               Stroke="#22FFFFFF"
                               StrokeThickness="1"
                               X1="0"
                               X2="1"
                               Y1="0.5"
                               Y2="0.5" />
                           <Line
                               Stretch="Uniform"
                               Stroke="#22FFFFFF"
                               StrokeThickness="1"
                               X1="0.5"
                               X2="0.5"
                               Y1="0"
                               Y2="1" />
                       </Grid>
                   </Border>
               </TabItem>-->

                <!--  Mess设置 Tab  -->
                <TabItem Header="MES 设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12" Orientation="Vertical">
                            <!--  设备信息卡片  -->
                            <materialDesign:Card
                               Margin="0,0,0,12"
                               Padding="16"
                               Effect="{StaticResource MaterialDesignShadowDepth1}">
                                <StackPanel>
                                    <TextBlock
                                       Margin="0,0,0,12"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="设备信息" />
                                    <UniformGrid Margin="0,0,0,0" Columns="6">
                                        <Label
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="设备编号:" />
                                        <TextBox
                                           Margin="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}"
                                           Text="MC-10086" />
                                        <Label
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="工站:" />
                                        <TextBox
                                           Margin="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}"
                                           Text="Station-01" />
                                        <Label
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="节点代码:" />
                                        <TextBox
                                           Margin="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}"
                                           Text="NODE_A1" />
                                    </UniformGrid>
                                </StackPanel>
                            </materialDesign:Card>

                            <!--  工单查询卡片  -->
                            <materialDesign:Card
                               Margin="0,0,0,12"
                               Padding="16"
                               Effect="{StaticResource MaterialDesignShadowDepth1}">
                                <StackPanel>
                                    <TextBlock
                                       Margin="0,0,0,12"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="工单查询" />
                                    <DockPanel LastChildFill="True">
                                        <Button
                                           Width="100"
                                           Margin="8,0,0,0"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Content="选中工单"
                                           DockPanel.Dock="Right"
                                           Style="{StaticResource MaterialDesignRaisedButton}" />
                                        <DataGrid
                                           Height="150"
                                           HorizontalAlignment="Stretch"
                                           AutoGenerateColumns="False"
                                           DockPanel.Dock="Left"
                                           IsReadOnly="True"
                                         ItemsSource="{Binding Orders}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                   Width="*"
                                                   Binding="{Binding OrderNo}"
                                                   Header="工单号" />
                                                <DataGridTextColumn
                                                   Width="*"
                                                   Binding="{Binding Product}"
                                                   Header="产品" />
                                                <DataGridTextColumn
                                                   Width="80"
                                                   Binding="{Binding Quantity}"
                                                   Header="数量" />
                                                <DataGridTextColumn
                                                   Width="80"
                                                   Binding="{Binding Status}"
                                                   Header="状态" />
                                            </DataGrid.Columns>
                                            <!--  设计时预览数据  -->
                                            <d:DataGrid.ItemsSource>
                                                <x:Array Type="{x:Type sys:String}">
                                                    <sys:String>WO2024001</sys:String>
                                                    <sys:String>WO2024002</sys:String>
                                                </x:Array>
                                            </d:DataGrid.ItemsSource>
                                        </DataGrid>
                                    </DockPanel>
                                </StackPanel>
                            </materialDesign:Card>

                            <!--  过站操作卡片  -->
                            <materialDesign:Card
                               Margin="0,0,0,12"
                               Padding="16"
                               Effect="{StaticResource MaterialDesignShadowDepth1}">
                                <StackPanel>
                                    <TextBlock
                                       Margin="0,0,0,12"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="过站操作" />
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  托盘码  -->
                                        <Label
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="托盘码:" />
                                        <TextBox
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           Margin="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}" />

                                        <!--  扫描信息  -->
                                        <Label
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="扫描信息:" 
                                            />
                                        <TextBox
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="4"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}" 
                                            Text="{Binding ScanInfo}"/>

                                        <!--  投入/产出  -->
                                        <StackPanel
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="3"
                                           Margin="4,8,0,8"
                                           Orientation="Horizontal">
                                            <RadioButton
                                               Margin="0,0,24,0"
                                               VerticalAlignment="Center"
                                               Content="投入"
                                               IsChecked="{Binding IsInput}"/>
                                            <RadioButton VerticalAlignment="Center" Content="产出" />
                                        </StackPanel>

                                        <!--  结果显示  -->
                                        <Label
                                           Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           HorizontalContentAlignment="Right"
                                           Content="结果:" />
                                        <Border
                                           Grid.Row="3"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="3"
                                           Margin="4"
                                           Padding="8,4"
                                           Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                                           CornerRadius="4">
                                            <TextBlock
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="{Binding ResultText}" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                            <!--  底部操作栏  -->
                            <materialDesign:Card Padding="16,12" Effect="{StaticResource MaterialDesignShadowDepth1}">
                                <DockPanel>
                                    <Button
                                       Width="100"
                                       Margin="0,0,16,0"
                                       HorizontalAlignment="Left"
                                       Content="数据保存"
                                       DockPanel.Dock="Left"
                                       Style="{StaticResource MaterialDesignRaisedButton}" />
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Label VerticalAlignment="Center" Content="发送保存事件:" />
                                        <TextBox
                                           Width="60"
                                           Margin="8,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MaterialDesignTextBox}"
                                           Text="7" />
                                        <Label VerticalAlignment="Center" Content="天" />
                                        <Button
                                           Margin="16,0,0,0"
                                           Content="立即发送"
                                            Command="{ Binding SendTrackOutCommand}"
                                           Style="{StaticResource MaterialDesignFlatButton}" />
                                    </StackPanel>
                                </DockPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!--  ========== 第三列：信息面板 / 日志 ==========  -->
            <Border
               Grid.Column="2"
               Margin="8,8,8,8"
               Background="{DynamicResource MaterialDesignCardBackground}"
               BorderBrush="{DynamicResource MaterialDesignDivider}"
               BorderThickness="1"
               CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  日志列表区域  -->
                    <Border
                       Grid.Row="0"
                       BorderBrush="{DynamicResource MaterialDesignDivider}"
                       BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock
                               Margin="16,12,16,8"
                               DockPanel.Dock="Top"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="事件日志" />
                            <ListBox
                               Margin="8,0,8,8"
                               Background="Transparent"
                               BorderThickness="0"
                               ItemContainerStyle="{StaticResource MaterialDesignListBoxItem}"
                               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemsSource="{Binding EventLogs}">
                                <!--<ListBoxItem>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                           Width="12"
                                           Height="12"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="LimeGreen"
                                           Kind="CheckCircle" />
                                        <TextBlock FontSize="11" Text="[10:23:15] 设备初始化完成" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                           Width="12"
                                           Height="12"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="DodgerBlue"
                                           Kind="Information" />
                                        <TextBlock FontSize="11" Text="[10:24:02] 等待工单载入..." />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                           Width="12"
                                           Height="12"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="Orange"
                                           Kind="Alert" />
                                        <TextBlock FontSize="11" Text="[10:25:30] 托盘码未扫描" />
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                           Width="12"
                                           Height="12"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="LimeGreen"
                                           Kind="CheckCircle" />
                                        <TextBlock FontSize="11" Text="[10:26:47] 工单WO2024001 已加载" />
                                    </StackPanel>
                                </ListBoxItem>-->
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!--  SN 状态栏  -->
                    <Border
                       Grid.Row="1"
                       Padding="16,10"
                       BorderBrush="{DynamicResource MaterialDesignDivider}"
                       BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="SN:" />
                            <StackPanel
                               Grid.Column="1"
                               HorizontalAlignment="Right"
                               Orientation="Horizontal">
                                <materialDesign:PackIcon
                                   Width="12"
                                   Height="12"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"
                                   Foreground="Red"
                                   Kind="Circle" />
                                <TextBlock
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="Red"
                                   Text="状态未连接" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  扫码输入框  -->
                    <Border Grid.Row="2" Padding="16,12">
                        <TextBox
                           materialDesign:HintAssist.Hint="扫码或手动输入SN"
                           Style="{StaticResource MaterialDesignTextBox}"
                           Text="SN20240315001" />
                    </Border>

                    <!--  检测结果  -->
                    <Border
                       Grid.Row="3"
                       Margin="16,0,16,16"
                       Padding="12,8"
                       Background="{DynamicResource MaterialDesignTextFieldBoxBackground}"
                       CornerRadius="4">
                        <DockPanel>
                            <TextBlock
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="结果:" />
                            <TextBlock
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="LimeGreen"
                               Text="OK" />
                            <TextBlock
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Text="PASS" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!--  第三行：底部状态栏  -->
        <materialDesign:ColorZone
           Grid.Row="2"
           Padding="12,4"
           Mode="Standard">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                       VerticalAlignment="Center"
                       FontSize="11"
                       Text="© 2025 捷翔工业 · CCD 检测系统" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <materialDesign:PackIcon
                       Width="14"
                       Height="14"
                       Margin="0,0,4,0"
