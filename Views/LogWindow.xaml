<UserControl
    x:Class="AppMeS.Views.LogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Com="clr-namespace:AppMeS.Comm"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:AppMeS.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Width="400"
    Height="480"
    d:DesignHeight="450"
    d:DesignWidth="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <materialDesign:Card
        Margin="20"
        Padding="30,20"
        Background="{DynamicResource MaterialDesignPaper}"
        Effect="{StaticResource MaterialDesignShadowDepth4}"
        UniformCornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  顶部图标与标题  -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                <materialDesign:PackIcon
                    Width="48"
                    Height="48"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource PrimaryHueMidBrush}"
                    Kind="CameraIris" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="CCD 检测系统" />
                <TextBlock
                    Margin="0,5,0,20"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesignBodyLight}"
                    Text="请登录以继续" />
            </StackPanel>

            <!--  登录表单  -->
            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <!--  用户名  -->
                <TextBox
                    Margin="0,0,0,15"
                    materialDesign:HintAssist.Hint="用户名"
                    materialDesign:HintAssist.IsFloating="True"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding UserName}" />

                <!--  密码  -->
                <PasswordBox
                    Margin="0,0,0,10"
                    Com:PasswordBoxHelper.BoundPassword="{Binding PassWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Com:PasswordBoxHelper.EnablePasswordBinding="True"
                    materialDesign:HintAssist.Hint="密码"
                    materialDesign:HintAssist.IsFloating="True"
                    Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

                <!--  记住密码 & 忘记密码  -->
                <Grid Margin="0,5,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                        x:Name="RememberMeCheckBox"
                        Grid.Column="0"
                        Content="记住密码"
                        IsChecked="True" />
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        FontSize="12"
                        Foreground="{DynamicResource PrimaryHueMidBrush}"
                        Text="忘记密码？">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding ForgotPasswordCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </TextBlock>
                </Grid>

                <!--  登录按钮  -->
                <Button
                    x:Name="LoginButton"
                    Height="40"
                    Command="{Binding LoginCommand}"
                    Content="登 录"
                    IsDefault="True"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            </StackPanel>

            <!--  底部版本信息  -->
            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Center"
                FontSize="10"
                Foreground="{DynamicResource MaterialDesignBodyLight}"
                Text="版本 2.1.0 · 内部测试" />
        </Grid>
    </materialDesign:Card>
</UserControl>
